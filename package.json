{
  "name": "amstrad-cpc-debug",
  "displayName": "Amstrad CPC Debug",
  "description": "VS Code debugger for Amstrad CPC Z80 development — connects to any emulator implementing the amstrad-cpc-debug TCP protocol",
  "version": "0.0.3",
  "publisher": "thomas-guillemin",
  "engines": {
    "vscode": "^1.108.0"
  },
  "categories": [
    "Debuggers"
  ],
  "activationEvents": [
    "onDebug",
    "onStartupFinished"
  ],
  "main": "./dist/main.js",
  "contributes": {
    "configuration": {
      "title": "%cfg.title%",
      "properties": {
        "z80debug.entryPoint": {
          "type": "string",
          "default": "src/main.asm",
          "description": "%cfg.entryPoint.desc%"
        },
        "z80debug.buildName": {
          "type": "string",
          "default": "main",
          "description": "%cfg.buildName.desc%"
        },
        "z80debug.sugarbox": {
          "type": "string",
          "default": "",
          "description": "%cfg.sugarbox.desc%"
        },
        "z80debug.rasm": {
          "type": "string",
          "default": "rasm",
          "description": "%cfg.rasm.desc%"
        },
        "z80debug.hideEmulator": {
          "type": "boolean",
          "default": false,
          "description": "%cfg.hideEmulator.desc%"
        }
      }
    },
    "languages": [
      {
        "id": "z80-disasm",
        "aliases": [
          "Z80 Disassembly"
        ],
        "extensions": [
          ".z80disasm"
        ],
        "mimetypes": [
          "text/x-z80-disasm"
        ]
      }
    ],
    "grammars": [
      {
        "language": "z80-disasm",
        "scopeName": "source.z80disasm",
        "path": "./syntaxes/z80-disasm.tmGrammar.json"
      }
    ],
    "commands": [
      {
        "command": "z80debug.newProject",
        "title": "%cmd.newProject%",
        "category": "Z80 Debug"
      },
      {
        "command": "z80debug.quickLaunch",
        "title": "%cmd.quickLaunch%",
        "category": "Z80 Debug"
      },
      {
        "command": "z80debug.configure",
        "title": "%cmd.configure%",
        "category": "Z80 Debug"
      },
      {
        "command": "z80debug.openDisasmAt",
        "title": "%cmd.openDisasmAt%",
        "category": "Z80 Debug"
      },
      {
        "command": "z80debug.openMemoryAt",
        "title": "%cmd.openMemoryAt%",
        "category": "Z80 Debug"
      },
      {
        "command": "z80debug.addBreakpointAt",
        "title": "%cmd.addBreakpointAt%",
        "category": "Z80 Debug"
      },
      {
        "command": "z80debug.toggleBreakpointAt",
        "title": "%cmd.toggleBreakpointAt%",
        "category": "Z80 Debug"
      },
      {
        "command": "z80debug.showCrtcPanel",
        "title": "%cmd.showCrtcPanel%",
        "category": "Z80 Debug"
      },
      {
        "command": "z80debug.showGateArrayPanel",
        "title": "%cmd.showGateArrayPanel%",
        "category": "Z80 Debug"
      },
      {
        "command": "z80debug.showPsgPanel",
        "title": "%cmd.showPsgPanel%",
        "category": "Z80 Debug"
      },
      {
        "command": "z80debug.showFdcPanel",
        "title": "%cmd.showFdcPanel%",
        "category": "Z80 Debug"
      },
      {
        "command": "z80debug.showPpiPanel",
        "title": "%cmd.showPpiPanel%",
        "category": "Z80 Debug"
      },
      {
        "command": "z80debug.showTapePanel",
        "title": "%cmd.showTapePanel%",
        "category": "Z80 Debug"
      }
    ],
    "viewsWelcome": [
      {
        "view": "z80debug.launcher",
        "contents": "%view.launcher.welcome%"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "z80-debug-sidebar",
          "title": "Z80 Debug",
          "icon": "images/activity-bar.svg"
        }
      ]
    },
    "views": {
      "z80-debug-sidebar": [
        {
          "id": "z80debug.launcher",
          "name": "%view.launcher%",
          "visibility": "visible"
        },
        {
          "id": "z80debug.hardwarePanels",
          "name": "%view.hardware%",
          "visibility": "visible"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "z80debug.openDisasmAt",
          "when": "debugState == 'stopped'",
          "group": "z80debug@1"
        },
        {
          "command": "z80debug.openMemoryAt",
          "when": "debugState == 'stopped'",
          "group": "z80debug@2"
        },
        {
          "command": "z80debug.toggleBreakpointAt",
          "when": "editorLangId == 'z80-disasm' && debugState == 'stopped'",
          "group": "z80debug@3"
        },
        {
          "command": "z80debug.addBreakpointAt",
          "when": "debugType == 'z80' && debugState == 'stopped'",
          "group": "z80debug@4"
        }
      ],
      "debug/variables/context": [
        {
          "command": "z80debug.openMemoryAt",
          "when": "debugType == 'z80' && debugState == 'stopped'",
          "group": "z80debug@1"
        },
        {
          "command": "z80debug.openDisasmAt",
          "when": "debugType == 'z80' && debugState == 'stopped'",
          "group": "z80debug@2"
        }
      ],
      "commandPalette": [
        {
          "command": "z80debug.newProject"
        },
        {
          "command": "z80debug.quickLaunch"
        },
        {
          "command": "z80debug.openDisasmAt",
          "when": "debugState == 'stopped'"
        },
        {
          "command": "z80debug.openMemoryAt",
          "when": "debugState == 'stopped'"
        },
        {
          "command": "z80debug.addBreakpointAt",
          "when": "debugState == 'stopped'"
        },
        {
          "command": "z80debug.toggleBreakpointAt",
          "when": "editorLangId == 'z80-disasm' && debugState == 'stopped'"
        }
      ]
    },
    "keybindings": [
      {
        "command": "z80debug.openDisasmAt",
        "key": "ctrl+alt+d",
        "mac": "cmd+alt+d",
        "when": "debugState == 'stopped'"
      },
      {
        "command": "z80debug.openMemoryAt",
        "key": "ctrl+alt+m",
        "mac": "cmd+alt+m",
        "when": "debugState == 'stopped'"
      },
      {
        "command": "z80debug.toggleBreakpointAt",
        "key": "F9",
        "when": "editorLangId == 'z80-disasm'"
      },
      {
        "command": "z80debug.addBreakpointAt",
        "key": "ctrl+alt+b",
        "mac": "cmd+alt+b",
        "when": "debugType == 'z80' && debugState == 'stopped'"
      }
    ],
    "debuggers": [
      {
        "type": "z80",
        "label": "%dbg.label%",
        "program": "./out/main.js",
        "runtime": "node",
        "languages": [
          "asm"
        ],
        "initialConfigurations": [
          {
            "type": "z80",
            "request": "launch",
            "name": "Amstrad CPC - Launch",
            "emulator": "${config:z80debug.sugarbox}",
            "disk": "${workspaceFolder}/build/${config:z80debug.buildName}.dsk",
            "symbolFile": "${workspaceFolder}/build/${config:z80debug.buildName}.rasm",
            "port": 1234,
            "hideEmulator": false,
            "preLaunchTask": "RASM: assemble"
          }
        ],
        "configurationSnippets": [
          {
            "label": "%snippet.diskRasm.label%",
            "description": "%snippet.diskRasm.desc%",
            "body": {
              "type": "z80",
              "request": "launch",
              "name": "Amstrad CPC - Launch",
              "emulator": "^\"\\${config:z80debug.sugarbox}\"",
              "disk": "^\"\\${workspaceFolder}/build/\\${config:z80debug.buildName}.dsk\"",
              "symbolFile": "^\"\\${workspaceFolder}/build/\\${config:z80debug.buildName}.rasm\"",
              "port": 1234,
              "hideEmulator": false,
              "preLaunchTask": "RASM: assemble"
            }
          },
          {
            "label": "%snippet.snapshotBuild.label%",
            "description": "%snippet.snapshotBuild.desc%",
            "body": {
              "type": "z80",
              "request": "launch",
              "name": "Amstrad CPC - Snapshot",
              "emulator": "^\"\\${config:z80debug.sugarbox}\"",
              "snapshot": "^\"\\${workspaceFolder}/build/\\${config:z80debug.buildName}.sna\"",
              "symbolFile": "^\"\\${workspaceFolder}/build/\\${config:z80debug.buildName}.rasm\"",
              "port": 1234,
              "hideEmulator": false,
              "preLaunchTask": "RASM: assemble"
            }
          },
          {
            "label": "%snippet.snapshot.label%",
            "description": "%snippet.snapshot.desc%",
            "body": {
              "type": "z80",
              "request": "launch",
              "name": "Amstrad CPC - Snapshot",
              "emulator": "^\"\\${config:z80debug.sugarbox}\"",
              "snapshot": "^\"\\${workspaceFolder}/build/\\${config:z80debug.buildName}.sna\"",
              "symbolFile": "^\"\\${workspaceFolder}/build/\\${config:z80debug.buildName}.rasm\"",
              "port": 1234,
              "hideEmulator": false
            }
          },
          {
            "label": "%snippet.attach.label%",
            "description": "%snippet.attach.desc%",
            "body": {
              "type": "z80",
              "request": "attach",
              "name": "Amstrad CPC - Attach",
              "port": 1234,
              "symbolFile": "^\"\\${workspaceFolder}/build/\\${config:z80debug.buildName}.rasm\""
            }
          },
          {
            "label": "%snippet.plain.label%",
            "description": "%snippet.plain.desc%",
            "body": {
              "type": "z80",
              "request": "launch",
              "name": "Amstrad CPC - Plain",
              "emulator": "^\"\\${config:z80debug.sugarbox}\"",
              "port": 1234,
              "hideEmulator": false
            }
          },
          {
            "label": "%snippet.diskOneshot.label%",
            "description": "%snippet.diskOneshot.desc%",
            "body": {
              "type": "z80",
              "request": "launch",
              "name": "Amstrad CPC - Disk",
              "emulator": "^\"\\${config:z80debug.sugarbox}\"",
              "disk": "^\"\\${workspaceFolder}/disk.dsk\"",
              "port": 1234,
              "hideEmulator": false
            }
          },
          {
            "label": "%snippet.tapeOneshot.label%",
            "description": "%snippet.tapeOneshot.desc%",
            "body": {
              "type": "z80",
              "request": "launch",
              "name": "Amstrad CPC - Tape",
              "emulator": "^\"\\${config:z80debug.sugarbox}\"",
              "tape": "^\"\\${workspaceFolder}/tape.cdt\"",
              "port": 1234,
              "hideEmulator": false
            }
          },
          {
            "label": "%snippet.cartridge.label%",
            "description": "%snippet.cartridge.desc%",
            "body": {
              "type": "z80",
              "request": "launch",
              "name": "Amstrad CPC+ - Cartridge",
              "emulator": "^\"\\${config:z80debug.sugarbox}\"",
              "cartridge": "^\"\\${workspaceFolder}/cart.cpr\"",
              "configuration": "CPC+",
              "port": 1234,
              "hideEmulator": false
            }
          }
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "emulator"
            ],
            "properties": {
              "emulator": {
                "type": "string",
                "description": "%attr.emulator.desc%"
              },
              "configuration": {
                "type": "string",
                "description": "%attr.configuration.desc%"
              },
              "disk": {
                "type": "string",
                "description": "%attr.disk.desc%"
              },
              "diskB": {
                "type": "string",
                "description": "%attr.diskB.desc%"
              },
              "tape": {
                "type": "string",
                "description": "%attr.tape.desc%"
              },
              "snapshot": {
                "type": "string",
                "description": "%attr.snapshot.desc%"
              },
              "cartridge": {
                "type": "string",
                "description": "%attr.cartridge.desc%"
              },
              "port": {
                "type": "number",
                "default": 1234,
                "description": "%attr.port.desc%"
              },
              "symbolFile": {
                "type": "string",
                "description": "%attr.symbolFile.desc%"
              },
              "sourceFile": {
                "type": "string",
                "description": "%attr.sourceFile.desc%"
              },
              "hideEmulator": {
                "type": "boolean",
                "default": false,
                "description": "%attr.hideEmulator.desc%"
              }
            }
          },
          "attach": {
            "required": [],
            "properties": {
              "port": {
                "type": "number",
                "default": 1234,
                "description": "%attr.port.desc%"
              },
              "symbolFile": {
                "type": "string",
                "description": "%attr.symbolFile.desc%"
              },
              "sourceFile": {
                "type": "string",
                "description": "%attr.sourceFile.desc%"
              }
            }
          }
        }
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "bundle": "npm run compile && webpack --config webpack.config.js",
    "watch": "tsc -w",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.19.30",
    "@types/vscode": "^1.108.1",
    "@vscode/vsce": "^2.15.0",
    "typescript": "^5.3.0",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "vscode-debugadapter": "^1.51.0",
    "vscode-debugprotocol": "^1.51.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
